<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Zubrilka.Views.PlaybackPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:b="clr-namespace:Zubrilka.Behaviors"
    xmlns:conv="clr-namespace:Zubrilka.Converters"
    xmlns:vm="clr-namespace:Zubrilka.ViewModels"
    x:Name="Page"
    x:DataType="vm:PlaybackViewModel"
    Title="{Binding Title}">

    <ContentPage.Resources>
        <conv:BoolToFlowDirectionConverter x:Key="BoolToFlowDirection" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- One equally-sized pane per selected language (FlexLayout column, Grow=1). -->
        <FlexLayout
            Grid.Row="0"
            Direction="Column"
            BindableLayout.ItemsSource="{Binding Panes}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:LanguagePane">
                    <Border
                        FlexLayout.Grow="1"
                        FlexLayout.Basis="0"
                        Margin="6"
                        Padding="8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10">

                        <!-- Highlight the pane whose phrase is being spoken. -->
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                <Setter Property="BackgroundColor" Value="#332B7FFF" />
                            </DataTrigger>
                        </Border.Triggers>

                        <Grid RowDefinitions="Auto,*">
                            <!-- Language code caption -->
                            <Label
                                Grid.Row="0"
                                Text="{Binding Code}"
                                FontSize="12"
                                Opacity="0.6" />

                            <!-- The phrase: centered, RTL-aware, auto-shrunk to fit the pane. -->
                            <Label
                                Grid.Row="1"
                                Text="{Binding Text}"
                                FlowDirection="{Binding Rtl, Converter={StaticResource BoolToFlowDirection}}"
                                HorizontalTextAlignment="Center"
                                VerticalTextAlignment="Center"
                                LineBreakMode="WordWrap">
                                <Label.Behaviors>
                                    <b:FitFontBehavior MaxFontSize="{Binding MaxFontSize}" MinFontSize="12" />
                                </Label.Behaviors>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>

        <!-- Playback controls -->
        <Grid Grid.Row="1" Padding="12" ColumnSpacing="12" ColumnDefinitions="*,*">
            <Button Grid.Column="0" Text="{Binding PauseButtonText}" Command="{Binding TogglePauseCommand}" />
            <Button Grid.Column="1" Text="Exit" Command="{Binding ExitCommand}" />
        </Grid>
    </Grid>
</ContentPage>
