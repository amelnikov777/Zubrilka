<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Zubrilka.Views.PlaybackPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Zubrilka.ViewModels"
    x:DataType="vm:PlaybackViewModel"
    Title="{Binding Title}">

    <!-- Row 0 holds the language panes, row 1 the controls. The panes grid is filled in
         code-behind with two rows per language (Auto caption + star-sized phrase box), so
         the panes always divide exactly the space above the buttons and never overlap them. -->
    <Grid RowDefinitions="*,Auto">

        <Grid x:Name="PanesGrid" Grid.Row="0" Padding="6,0,6,0" />

        <!-- Pause sits on the right: it is the button used most, and the right half is the
             easier thumb reach. -->
        <Grid Grid.Row="1" Padding="12" ColumnSpacing="12" ColumnDefinitions="*,*">
            <Button Grid.Column="0" Text="Exit" Command="{Binding ExitCommand}" />
            <Button Grid.Column="1" Text="{Binding PauseButtonText}" Command="{Binding TogglePauseCommand}" />
        </Grid>
    </Grid>
</ContentPage>
